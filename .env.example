# ── AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...              # Google AI Studio → free tier generous

# ── GST API (Masters India) ───────────────────────────
MASTERS_INDIA_API_KEY=your_key_here
MASTERS_INDIA_BASE_URL=https://commonapi.mastersindia.co

# ── WhatsApp (Meta Cloud API) ─────────────────────────
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=any_random_string_you_choose  # for webhook verification

# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ── App ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ADMIN_SECRET=change_me_in_prod     # for POST /api/admin/run-alerts
